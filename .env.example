# Firebase Web SDK (for the React app)
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:...

# Firebase Admin (for serverless functions)
# Get from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXX\n-----END PRIVATE KEY-----\n"

# Meta / Facebook App (for Instagram + Facebook API)
# Get from https://developers.facebook.com → Your App → Settings → Basic
VITE_META_APP_ID=123456789
META_APP_ID=123456789
META_APP_SECRET=abc123def456

# App URL
VITE_APP_URL=https://patrickcontrol.vercel.app
